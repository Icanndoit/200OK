# Google OAuth2
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth2
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# JWT
JWT_SECRET=your-base64-encoded-secret-key
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# OAuth2 redirect
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/callback

# AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# 로컬 개발: http://localhost:8000 / 실제 AWS: 빈칸
DYNAMODB_ENDPOINT=

# Kakao Pay (카카오페이 가맹점 센터에서 발급)
KAKAO_PAY_SECRET_KEY=your-kakao-pay-secret-key
KAKAO_PAY_CID=TC0ONETIME
# 결제 완료/취소/실패 후 카카오가 리다이렉트할 URL (앱 딥링크 또는 프론트 URL)
KAKAO_PAY_APPROVAL_URL=http://localhost:3000/payment/success
KAKAO_PAY_CANCEL_URL=http://localhost:3000/payment/cancel
KAKAO_PAY_FAIL_URL=http://localhost:3000/payment/fail
# 프리미엄 1개월 가격 (원), 미설정 시 기본값 9900
KAKAO_PAY_PREMIUM_PRICE=9900

# Google Play Billing
# 안드로이드 앱 패키지명 (build.gradle의 applicationId)
GOOGLE_PLAY_PACKAGE_NAME=com.checkdang
# GCP 서비스 계정 JSON 키를 Base64 인코딩한 값
# 발급: GCP Console → IAM → 서비스 계정 → 키 탭 → JSON 다운로드
# 인코딩: base64 -i service-account.json | tr -d '\n'
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=your-base64-encoded-service-account-json
# Google Play Console에서 생성한 구독 상품 ID
# ※ Play Console 4단계 완료 전까지는 아래 플레이스홀더 유지
#   → 서버 기동은 정상이나 /api/payment/google/verify 실제 호출 시 Google API 404 반환
# ※ Play Console 4단계 완료 후: 실제 구독 상품 ID로 교체
#   예) Play Console → 앱 선택 → 수익 창출 → 구독 → 상품 ID 확인
GOOGLE_PLAY_SUBSCRIPTION_ID=premium_monthly
