<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_secondary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_primary"
        android:elevation="2dp"
        app:title="프리미엄 구독"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.CheckDang.Title2" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- 상단 타이틀 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="체크당 PRO"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/brand_green"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="당신과 가족의 건강을 지키는\n가장 완벽한 방법"
                android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="28dp" />

            <!-- 혜택 리스트 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRO 혜택"
                        android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <include layout="@layout/item_benefit_row" android:id="@+id/benefit_1" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <include layout="@layout/item_benefit_row" android:id="@+id/benefit_2" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <include layout="@layout/item_benefit_row" android:id="@+id/benefit_3" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <include layout="@layout/item_benefit_row" android:id="@+id/benefit_4" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <include layout="@layout/item_benefit_row" android:id="@+id/benefit_5" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <include layout="@layout/item_benefit_row" android:id="@+id/benefit_6" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 가격 카드 2개 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- 월간 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_monthly"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/background_primary"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/divider">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="월간"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₩5,900"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/ 월"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 연간 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_yearly"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/brand_green_light"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/brand_green">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <!-- 할인 뱃지 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30% 할인"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@drawable/bg_chip"
                            android:backgroundTint="@color/brand_green"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="연간"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/brand_green"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₩49,000"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/brand_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/ 년 (월 ₩4,083)"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/brand_green" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 구독 시작 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_subscribe"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="구독 시작하기"
                android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                android:layout_marginBottom="16dp"
                app:cornerRadius="16dp" />

            <!-- 결제 약관 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="구독은 자동으로 갱신되며, 갱신 24시간 전에 취소하지 않으면 자동 결제됩니다.\n구독 관리 및 취소는 기기 설정 > 구독에서 가능합니다."
                android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                android:textColor="@color/text_secondary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
