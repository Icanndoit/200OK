<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <!-- 완료 아이콘 대체 텍스트 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="✓"
            android:textSize="48sp"
            android:textColor="@color/brand_green"
            android:layout_marginBottom="16dp" />

        <!-- 환영 메시지 -->
        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/onboarding_complete_title"
            android:textAppearance="@style/TextAppearance.CheckDang.Title1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/onboarding_complete_subtitle"
            android:textAppearance="@style/TextAppearance.CheckDang.Body2"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- 요약 카드 -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CheckDang.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tv_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                android:lineSpacingMultiplier="1.6"
                android:text="—" />

        </com.google.android.material.card.MaterialCardView>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <!-- 시작 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            style="@style/Widget.CheckDang.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_start" />

    </LinearLayout>
</ScrollView>
