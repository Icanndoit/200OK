<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_l">

        <!-- ===== Header ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="디자인 시스템"
            android:textAppearance="@style/TextAppearance.CheckDang.Title1"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- ===== 1. Color Palette ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="컬러 팔레트"
            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
            android:layout_marginBottom="@dimen/spacing_m" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CheckDang.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- brand_green -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/brand_green" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="brand_green" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#4CAF50" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- brand_green_dark -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/brand_green_dark" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="brand_green_dark" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#388E3C" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- brand_green_light -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/brand_green_light" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="brand_green_light" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#E8F5E9" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- background_secondary -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/background_secondary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="background_secondary" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#F7F8FA" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- status_normal -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/status_normal" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="status_normal" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#4CAF50" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- status_warning -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/status_warning" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="status_warning" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#FF9800" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- status_danger -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/status_danger" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="status_danger" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#F44336" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- status_normal_bg -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/status_normal_bg" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="status_normal_bg" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="alpha 15%" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- status_warning_bg -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="@dimen/spacing_s">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/status_warning_bg" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="status_warning_bg" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="alpha 15%" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

                <!-- status_danger_bg -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@color/status_danger_bg" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="@dimen/spacing_m"
                        android:text="status_danger_bg" android:textAppearance="@style/TextAppearance.CheckDang.Body2" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="alpha 15%" android:textAppearance="@style/TextAppearance.CheckDang.Caption" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 2. Typography ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="타이포그래피"
            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
            android:layout_marginBottom="@dimen/spacing_m" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CheckDang.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Display — 혈당 수치 표시용 (32sp Bold)"
                    android:textAppearance="@style/TextAppearance.CheckDang.Display"
                    android:layout_marginBottom="@dimen/spacing_m" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Title1 — 섹션 제목 (24sp Bold)"
                    android:textAppearance="@style/TextAppearance.CheckDang.Title1"
                    android:layout_marginBottom="@dimen/spacing_m" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Title2 — 카드 제목 (20sp SemiBold)"
                    android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                    android:layout_marginBottom="@dimen/spacing_m" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Body1 — 본문 텍스트 (16sp Regular)"
                    android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                    android:layout_marginBottom="@dimen/spacing_m" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Body2 — 보조 텍스트 (14sp Regular)"
                    android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                    android:layout_marginBottom="@dimen/spacing_m" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Caption — 캡션/레이블 (12sp Regular)"
                    android:textAppearance="@style/TextAppearance.CheckDang.Caption" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 3. Buttons ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="버튼"
            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
            android:layout_marginBottom="@dimen/spacing_m" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CheckDang.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.CheckDang.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Primary Button"
                    android:layout_marginBottom="@dimen/spacing_m" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.CheckDang.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Secondary Button" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 4. Card Sample ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="카드"
            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
            android:layout_marginBottom="@dimen/spacing_m" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CheckDang.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="카드 제목"
                    android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                    android:layout_marginBottom="@dimen/spacing_s" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="이것은 Widget.CheckDang.Card 스타일이 적용된 더미 카드입니다. radius 16dp, elevation 2dp."
                    android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 5. Status Chips ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="혈당 상태 칩"
            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
            android:layout_marginBottom="@dimen/spacing_m" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CheckDang.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Normal -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="정상"
                    android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                    android:textColor="@color/status_normal"
                    android:textStyle="bold"
                    android:background="@color/status_normal_bg"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:layout_marginEnd="@dimen/spacing_m" />

                <!-- Warning -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="주의"
                    android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                    android:textColor="@color/status_warning"
                    android:textStyle="bold"
                    android:background="@color/status_warning_bg"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:layout_marginEnd="@dimen/spacing_m" />

                <!-- Danger -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="위험"
                    android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                    android:textColor="@color/status_danger"
                    android:textStyle="bold"
                    android:background="@color/status_danger_bg"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 6. GlucoseEvaluator ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="혈당 상태 평가 (식후 2시간)"
            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
            android:layout_marginBottom="@dimen/spacing_m" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/spacing_xxl">

            <include
                android:id="@+id/card_glucose_80"
                layout="@layout/item_glucose_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_s" />

            <include
                android:id="@+id/card_glucose_150"
                layout="@layout/item_glucose_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_s" />

            <include
                android:id="@+id/card_glucose_220"
                layout="@layout/item_glucose_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
