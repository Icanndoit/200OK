<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/divider" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_part_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:textAppearance="@style/TextAppearance.CheckDang.Title2"
        android:textColor="@color/text_primary"
        tools:text="허리 통증 기록" />

    <!-- 통증 강도 레이블 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="통증 강도"
        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
        android:textColor="@color/text_primary" />

    <!-- Intensity dots -->
    <LinearLayout
        android:id="@+id/layout_intensity_dots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <View android:id="@+id/dot1"
            android:layout_width="28dp" android:layout_height="28dp"
            android:layout_marginHorizontal="6dp" android:background="@drawable/bg_intensity_dot" />
        <View android:id="@+id/dot2"
            android:layout_width="28dp" android:layout_height="28dp"
            android:layout_marginHorizontal="6dp" android:background="@drawable/bg_intensity_dot" />
        <View android:id="@+id/dot3"
            android:layout_width="28dp" android:layout_height="28dp"
            android:layout_marginHorizontal="6dp" android:background="@drawable/bg_intensity_dot" />
        <View android:id="@+id/dot4"
            android:layout_width="28dp" android:layout_height="28dp"
            android:layout_marginHorizontal="6dp" android:background="@drawable/bg_intensity_dot" />
        <View android:id="@+id/dot5"
            android:layout_width="28dp" android:layout_height="28dp"
            android:layout_marginHorizontal="6dp" android:background="@drawable/bg_intensity_dot" />
    </LinearLayout>

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/seekbar_intensity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:max="4"
        android:progress="2"
        android:progressTint="@color/brand_green"
        android:thumbTint="@color/brand_green" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="약함"
            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
            android:textColor="@color/text_secondary" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="심함"
            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 통증 유형 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="통증 유형 (복수 선택)"
        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
        android:textColor="@color/text_primary" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_pain_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:singleSelection="false"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_sharp"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="찌르는 통증" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_dull"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="둔한 통증" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_burning"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="타는 느낌" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_throbbing"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="욱신거림" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_stiffness"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="뻣뻣함" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_numbness"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="저림" />
    </com.google.android.material.chip.ChipGroup>

    <!-- AI 분석 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_analyze"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="AI 분석 받기"
        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />
</LinearLayout>
