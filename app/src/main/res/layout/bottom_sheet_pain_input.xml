<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="32dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@color/divider" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_part_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
            android:textColor="@color/text_primary"
            tools:text="허리 통증 기록"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- ── 세부 근육 선택 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="세부 근육 (선택)"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            android:textColor="@color/text_primary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_muscle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:singleSelection="true"
            app:selectionRequired="false" />

        <!-- ── 통증 강도 (1–10) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="통증 강도"
                android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_intensity_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                android:textColor="@color/brand_green"
                android:text="5 / 10" />
        </LinearLayout>

        <!-- Intensity dots (10개) -->
        <LinearLayout
            android:id="@+id/layout_intensity_dots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <View android:id="@+id/dot1"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot2"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot3"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot4"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot5"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot6"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot7"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot8"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot9"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
            <View android:id="@+id/dot10"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_marginHorizontal="3dp" android:background="@drawable/bg_intensity_dot" />
        </LinearLayout>

        <!-- SeekBar (max=9 → 0..9 = 1..10) -->
        <SeekBar
            android:id="@+id/seekbar_intensity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:max="9"
            android:progress="4"
            android:progressTint="@color/brand_green"
            android:thumbTint="@color/brand_green" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="약함"
                android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                android:textColor="@color/text_secondary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="심함"
                android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- ── 통증 유형 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="통증 유형 (복수 선택)"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            android:textColor="@color/text_primary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_pain_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_sharp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="찌르는 통증" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_dull"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="둔한 통증" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_burning"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="타는 느낌" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_throbbing"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="욱신거림" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_stiffness"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="뻣뻣함" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_numbness"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="저림" />
        </com.google.android.material.chip.ChipGroup>

        <!-- ── 버튼 2개 ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:text="저장하기"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_analyze"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="AI 분석 받기"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            app:cornerRadius="12dp"
            app:strokeColor="@color/brand_green"
            app:strokeWidth="1dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
