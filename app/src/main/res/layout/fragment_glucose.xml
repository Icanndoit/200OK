<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary">

    <!-- 콘텐츠 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background_primary"
            android:elevation="2dp"
            app:title="혈당 기록"
            app:titleTextColor="@color/text_primary"
            app:titleTextAppearance="@style/TextAppearance.CheckDang.Title2">

            <Button
                android:id="@+id/btn_pdf"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="PDF로 출력하기"
                android:textColor="@color/brand_green"
                android:textSize="12sp" />
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- 통계 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:weightSum="3">

                <!-- 이번 주 평균 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="이번 주 평균"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tv_stat_average"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                        tools:text="118" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="mg/dL"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/divider" />

                <!-- 최고 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="최고"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tv_stat_max"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                        android:textColor="@color/status_danger"
                        tools:text="172" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="mg/dL"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/divider" />

                <!-- 최저 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="최저"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tv_stat_min"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                        android:textColor="@color/status_warning"
                        tools:text="62" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="mg/dL"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TabLayout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@color/background_secondary"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/brand_green"
            app:tabIndicatorColor="@color/brand_green"
            app:tabIndicatorFullWidth="false"
            app:tabMode="fixed" />

        <!-- ViewPager2 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- FAB (BottomNav 위 16dp) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="혈당 입력"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/brand_green"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
