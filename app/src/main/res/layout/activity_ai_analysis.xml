<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_secondary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_primary"
        android:elevation="2dp"
        app:title="AI 바디맵 분석"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.CheckDang.Title2" />

    <!-- Loading State -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/brand_green"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI가 분석 중입니다…"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Result State -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layout_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- 통증 정보 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_result_part"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                            android:textColor="@color/text_primary"
                            tools:text="허리" />

                        <TextView
                            android:id="@+id/tv_result_types"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/text_secondary"
                            tools:text="둔한 통증 · 뻣뻣함" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_result_intensity"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                        android:textColor="@android:color/white"
                        android:background="@drawable/bg_intensity"
                        tools:text="3" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI 요약 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/brand_green_light"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="AI 분석 요약"
                        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                        android:textColor="@color/brand_green" />

                    <TextView
                        android:id="@+id/tv_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_primary"
                        tools:text="허리 통증 패턴 분석 결과…" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 상관관계 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="연관 요인"
                android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                android:textColor="@color/text_primary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_correlations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 추천 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="생활 습관 권장 사항"
                android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                android:textColor="@color/text_primary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/tv_recommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                    android:textColor="@color/text_primary"
                    tools:text="규칙적인 스트레칭…" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 면책 조항 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="⚠ 이 분석은 AI가 생성한 참고 정보이며 의학적 진단을 대체하지 않습니다. 지속적인 통증은 반드시 전문의와 상담하세요."
                android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                android:textColor="@color/text_secondary"
                android:background="@color/background_primary"
                android:padding="12dp" />

            <!-- 버튼 영역 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pdf"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="PDF 저장"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_confirm"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="확인"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
