<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── 헤더 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.CheckDang.Title2"
                android:textColor="@color/text_primary"
                tools:text="안녕하세요, 홍길동님" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                android:textColor="@color/text_secondary"
                tools:text="오늘 2024.01.15 월요일" />
        </LinearLayout>

        <!-- ── 메인 혈당 카드 ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_glucose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 데이터가 있을 때 -->
                <LinearLayout
                    android:id="@+id/layout_glucose_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- 혈당값 + 상태 뱃지 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_glucose_value"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/TextAppearance.CheckDang.Display"
                            tools:text="128"
                            tools:textColor="@color/brand_green" />

                        <TextView
                            android:id="@+id/tv_glucose_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:backgroundTint="@color/status_normal_bg"
                            android:background="@drawable/bg_chip"
                            tools:text="정상" />
                    </LinearLayout>

                    <!-- 단위 + 측정 시각 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="mg/dL"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_glucose_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary"
                        tools:text="14:30 · 식후 2시간" />

                    <!-- 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/divider" />

                    <!-- 오늘 측정 정보 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_today_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                            android:textColor="@color/text_secondary"
                            tools:text="오늘 측정 3회" />

                        <TextView
                            android:id="@+id/tv_today_average"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                            android:textColor="@color/text_secondary"
                            tools:text="평균 118 mg/dL" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 데이터가 없을 때 (빈 상태) -->
                <LinearLayout
                    android:id="@+id/layout_glucose_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="24dp"
                    android:visibility="visible">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_add"
                        android:alpha="0.3"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="오늘 기록이 없어요"
                        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="첫 혈당을 기록해 보세요"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add_glucose"
                        style="@style/Widget.CheckDang.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:minWidth="160dp"
                        android:minHeight="48dp"
                        android:paddingHorizontal="24dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:singleLine="true"
                        android:gravity="center"
                        android:text="혈당 입력하기"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="18dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 라이프스타일 섹션 타이틀 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:text="오늘의 라이프스타일"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            android:textColor="@color/text_primary" />

        <!-- ── 라이프스타일 카드 3개 (가로 배치) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- 운동 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_exercise"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="운동"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_exercise_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                        android:textColor="@color/text_primary"
                        tools:text="42/60분" />

                    <ProgressBar
                        android:id="@+id/progress_exercise"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progressTint="@color/brand_green"
                        android:progressBackgroundTint="@color/divider"
                        tools:progress="70" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 식사 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_meal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="식사"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_meal_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                        android:textColor="@color/text_primary"
                        tools:text="1,480 kcal" />

                    <ProgressBar
                        android:id="@+id/progress_meal"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progressTint="@color/brand_green"
                        android:progressBackgroundTint="@color/divider"
                        tools:progress="74" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 수면 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sleep"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="수면"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_sleep_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                        android:textColor="@color/text_primary"
                        tools:text="7.2시간" />

                    <TextView
                        android:id="@+id/tv_sleep_efficiency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                        android:textColor="@color/text_secondary"
                        tools:text="효율 84%" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── 주간 혈당 차트 섹션 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:text="7일 혈당 추이"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            android:textColor="@color/text_primary" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chart_weekly_glucose"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
