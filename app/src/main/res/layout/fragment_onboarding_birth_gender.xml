<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_step_birth_gender"
            android:textAppearance="@style/TextAppearance.CheckDang.Title1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="맞춤 혈당 분석에 활용됩니다."
            android:textAppearance="@style/TextAppearance.CheckDang.Body2"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- 생년월일 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_birth_date"
            style="@style/Widget.CheckDang.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_birth_date"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_today"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_birth_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:cursorVisible="false"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 성별 레이블 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="성별"
            android:textAppearance="@style/TextAppearance.CheckDang.Body2"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp" />

        <!-- 성별 토글 — 패턴 A: MaterialButtonToggleGroup -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_gender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_male"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/gender_male"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_female"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/gender_female"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/Widget.CheckDang.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:text="@string/btn_next" />

    </LinearLayout>
</ScrollView>
