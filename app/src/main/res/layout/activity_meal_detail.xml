<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_secondary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_primary"
        android:elevation="2dp"
        app:title="식사 상세"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.CheckDang.Title2" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- PieChart 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_macro"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />

                    <!-- 영양소 라벨 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView android:layout_width="10dp" android:layout_height="10dp"
                            android:src="@drawable/ic_dot" app:tint="@color/carbs_color" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="4dp" android:layout_marginEnd="16dp"
                            android:text="탄수화물"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/carbs_color" />

                        <ImageView android:layout_width="10dp" android:layout_height="10dp"
                            android:src="@drawable/ic_dot" app:tint="@color/protein_color" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="4dp" android:layout_marginEnd="16dp"
                            android:text="단백질"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/protein_color" />

                        <ImageView android:layout_width="10dp" android:layout_height="10dp"
                            android:src="@drawable/ic_dot" app:tint="@color/fat_color" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="지방"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/fat_color" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 칼로리 목표 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tv_kcal_value"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/TextAppearance.CheckDang.Display"
                            android:textColor="@color/text_primary"
                            tools:text="1,480 kcal" />

                        <TextView
                            android:id="@+id/tv_kcal_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
                            android:textColor="@color/text_secondary"
                            tools:text="/ 2,000 kcal (74%)" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_kcal"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progressTint="@color/brand_green"
                        android:progressBackgroundTint="@color/divider"
                        tools:progress="74" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 오늘의 식단 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="오늘의 식단"
                android:textAppearance="@style/TextAppearance.CheckDang.Body1"
                android:textColor="@color/text_primary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/layout_meals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ai_advice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Gemini 식단 조언 받기" />

            <TextView
                android:id="@+id/tv_ai_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textAppearance="@style/TextAppearance.CheckDang.Body2"
                android:textColor="@color/text_primary"
                tools:text="Gemini 응답이 여기에 표시됩니다." />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
