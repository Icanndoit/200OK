<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- 강도 원형 뱃지 -->
    <TextView
        android:id="@+id/tv_intensity"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.CheckDang.Body1"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_intensity"
        tools:text="3" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_part"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.CheckDang.Body1"
            android:textColor="@color/text_primary"
            tools:text="허리" />

        <TextView
            android:id="@+id/tv_pain_types"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.CheckDang.Caption"
            android:textColor="@color/text_secondary"
            tools:text="둔한 통증 · 뻣뻣함" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.CheckDang.Caption"
        android:textColor="@color/text_secondary"
        tools:text="2일 전" />
</LinearLayout>
